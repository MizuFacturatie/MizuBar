    function startFakePayment() {
        let bankSelect = document.getElementById("bankSelect");
        if (bankSelect.selectedIndex === 0 || bankSelect.value === "-- Selecteer uw bank --") {
            alert("Kies eerst uw bank om de betaling te voltooien.");
            return;
        }

        let btn = document.getElementById("payBtn");
        btn.disabled = true;
        btn.innerHTML = "‚Ź≥ Betaling verwerken...";
        
        let panel = document.getElementById("successPanel");
        panel.style.display = "block";
        document.getElementById("transactionId").innerHTML = "‚Ź≥ Transactie wordt verwerkt...";
        panel.scrollIntoView({ behavior: "smooth", block: "center" });
        
        setTimeout(function() {
            let txId = generateTransactionId();
            let qrCode = generateRandomQR();
            
            document.getElementById("qrCode").innerHTML = qrCode;
            document.getElementById("transactionId").innerHTML = txId;
            
            setTimeout(function() {
                let prankDiv = document.getElementById("prankReveal");
                prankDiv.style.display = "block";
                prankDiv.scrollIntoView({ behavior: "smooth", block: "center" });
                
                btn.innerHTML = "ūüėā Grap onthuld!";
                
                console.log("%c ūüé≠ MIZUBAR PRANK - Je collega heeft je te pakken! Geen echte betaling. ūüé≠", "color: #ff6600; font-size: 14px; font-weight: bold;");
            }, 800);
        }, 2000);
    }
